# このファイルはキー名のみ（値は空 or ダミー）。コピーして .env を作る:
#   cp .env.example .env
# .env は .gitignore 済み。実値は絶対にコミットしない。

# ─── pgvector (開発: docker compose の postgres) ───
POSTGRES_USER=biblio
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=biblio
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# アプリから使う接続文字列（上記から組み立て）
DATABASE_URL=postgresql://biblio:changeme_local_only@localhost:5432/biblio

# ─── 埋め込み (開発: Ollama) ───
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# ─── チャンク設定（②で参照・可変） ───
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# ─────────────────────────────────────────────
#  本番(AWS)移行時のみ使用。開発では不要・ダミーで足りる。
#  本番DB認証は Secrets Manager 経由。実キーはここにも .env にも置かない。
# ─────────────────────────────────────────────
# AWS_REGION=ap-northeast-1
# BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
# S3_BUCKET=
