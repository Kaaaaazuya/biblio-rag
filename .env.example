# このファイルはキー名のみ（値は空 or ダミー）。コピーして .env を作る:
#   cp .env.example .env
# .env は .gitignore 済み。実値は絶対にコミットしない。

# ─── pgvector (開発: docker compose の postgres) ───
POSTGRES_USER=biblio
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=biblio
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# アプリから使う接続文字列（上記から組み立て）
DATABASE_URL=postgresql://biblio:changeme_local_only@localhost:5432/biblio

# ─── 埋め込み (開発: Ollama) ───
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# ─── チャンク設定（②で参照・可変） ───
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# ─── オブジェクトストレージ（開発: MinIO / 本番: AWS S3） ───
# raw PDF はここに置く（将来 WebUI からアップロード）。本番は S3_ENDPOINT_URL を空に。
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=biblio
AWS_REGION=ap-northeast-1
# MinIO の開発用ダミー資格情報（docker-compose の MINIO_ROOT_* と一致）。本番は実キーを置かず IAM ロール。
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ─────────────────────────────────────────────
#  本番(AWS)移行時のみ使用。本番DB認証は Secrets Manager 経由。
# ─────────────────────────────────────────────
# BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
