{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git ls-files*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git check-ignore*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git stash*)",
      "Bash(git switch*)",
      "Bash(git tag*)",
      "Bash(uv *)",
      "Bash(pre-commit run*)",
      "Bash(docker compose *)",
      "Bash(docker ps*)",
      "Bash(docker logs*)",
      "Bash(docker images*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(jq*)",
      "Bash(lsof*)",
      "Bash(which*)",
      "Bash(echo*)",
      "Bash(curl http://localhost:*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git remote *)"
    ]
  }
}
